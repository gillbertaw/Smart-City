# =============================================
# SMART CITY - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and adjust values for your local machine.
# =============================================

# SERVER
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_secret_key
JWT_EXPIRES_IN=7d

# MYSQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartcity_medan
DB_USER=root
DB_PASSWORD=

# MONGODB
MONGO_URI=mongodb://localhost:27017/smartcity_logs

# UPLOAD
UPLOAD_PATH=uploads/
